# SAM.gov API Configuration
# Get your API key from: https://sam.gov/data-services/API
# SAM_GOV_API_KEY=your-sam-gov-api-key-here

# Tango API Configuration (Optional - for Tango tools)
# Get your API key from: https://tango.makegov.com/docs/
# TANGO_API_KEY=your-tango-api-key-here

# HigherGov API Configuration (Optional - for HigherGov tools)
# Get your API key from: https://highergov.com/docs/
# HIGHERGOV_API_KEY=your-highergov-api-key-here

# API Keys for data sources (optional - enables additional tools)

# ==============================================================================
# AWS Deployment Configuration (for CDK - optional)
# ==============================================================================

# AWS Account ID (required for hosted zone lookups)
# Find this in AWS Console or run: aws sts get-caller-identity --query Account
AWS_ACCOUNT=123456789012

# AWS Region for deployment (default: us-east-1)
AWS_REGION=us-east-1

# Custom domain name for the API (e.g., "mcp.example.com")
# If set, the CDK stack will:
#   1. Look up the Route53 hosted zone for the root domain (e.g., example.com)
#   2. Create an ACM certificate with DNS validation
#   3. Create a Route53 A record pointing to the API Gateway
# Prerequisites: Route53 hosted zone must exist for the root domain
DOMAIN_NAME=mcp.example.com
